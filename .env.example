DATABASE_URL=postgres://swamy:swamy@127.0.0.1:5433/swamy_sharanam
# Use a long random secret. Production refuses the default when DEV_AUTH=0.
JWT_SECRET=dev-change-me-swamy-sharanam-2026
BIND_ADDR=0.0.0.0:8080
# Local only: set DEV_AUTH=1 to accept DEV_OTP_CODE for any rostered phone.
# Defaults to 0 (off). Production must keep DEV_AUTH=0.
DEV_AUTH=1
DEV_OTP_CODE=123456
# Required when DEV_AUTH=0. Receives JSON with phone_e164, code, message,
# and expires_in_seconds. Return any 2xx response after accepting delivery.
# SMS_WEBHOOK_URL=https://your-sms-adapter.example.com/send-otp
# SMS_WEBHOOK_TOKEN=
UPLOAD_DIR=./uploads

# ─── Media storage ───
# local (default): files on disk under UPLOAD_DIR, served via signed API paths.
# s3: photos + video upload straight to S3 via presigned PUT, read from a
#     public CloudFront/S3 base URL. See docs/media-s3-setup.md.
MEDIA_BACKEND=local
# S3_BUCKET=sabarimala-yatra-media
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Public read base (no trailing slash). Prefer a CloudFront domain; falls back
# to S3_PUBLIC_URL if MEDIA_PUBLIC_BASE_URL is unset.
# MEDIA_PUBLIC_BASE_URL=https://dxxxxxxxxxxxx.cloudfront.net
# S3_PUBLIC_URL=https://sabarimala-yatra-media.s3.ap-south-1.amazonaws.com
# Custom S3-compatible endpoint (MinIO/local). Leave unset for real AWS S3.
# S3_ENDPOINT=http://localhost:9000

OPENAI_API_KEY=
# LLM_BACKEND=openai  # or qwen
# QWEN_BASE_URL=http://127.0.0.1:11434
# QWEN_MODEL=qwen2.5:7b

# FCM HTTP v1 (optional — see docs/fcm-setup.md)
# FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-sa.json
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=

# Optional later
# REDIS_URL=redis://127.0.0.1:6380
